MQTT_HOST=host.containers.internal
MQTT_PORT=21900
MQTT_AUTH_MODE=per-client
MQTT_CLIENT_PASSWORD=123456
CLIENTS=3500
TIMEUNIT=2
TIME=1
MSGS=10000
QOS=0
RETAIN=false

# MQTT_AUTH_MODE = per-client usa usuario DynSec 1..N. shared usa MQTT_USER/MQTT_PASS.
# MQTT_CLIENT_PASSWORD = Contraseña común de los usuarios DynSec 1..N.
# MQTT_USER = Usuario MQTT compartido si MQTT_AUTH_MODE=shared.
# MQTT_PASS = Contraseña MQTT compartida si MQTT_AUTH_MODE=shared.
# HOST = Host o IP del broker MQTT.
# PORT = Puerto del broker MQTT. En kind desde Windows usar localhost:21900.
# CLIENTS = Número de clientes a simular.
# TIMEUNIT = Unidad de tiempo (1=horas, 2=minutos, 3=segundos, 4=milisegundos).
# TIME = Intervalo entre mensajes de un cliente.
# MSGS = Cantidad de interacciones por cliente.
# QOS = Calidad de servicio para publicaciones (0, 1 o 2).
# RETAIN = Si los mensajes publicados deben quedar retenidos.