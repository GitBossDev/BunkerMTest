MQTT_HOST=localhost
MQTT_PORT=21900
MQTT_AUTH_MODE=per-client
MQTT_CLIENT_PASSWORD=123456
CLIENTS=750
TIMEUNIT=3
TIME=20
MSGS=10000
QOS=0
RETAIN=false

# User = Usuario, PASS = Contraseña.
# HOST = Host del broker MQTT
# PORT = Puerto del broker MQTT. En kind desde Windows usar localhost:21900.
# CLIENTS = Número de clientes a simular,
# TIMEUNIT = Unidad de tiempo (1=horas, 2=minutos, 3=segundos, 4=milisegundos)
# TIME = Cantidad de unidades de tiempo entre mensajes de un cliente. 
# MSGS = Cantidad de interacciones que tendrá cada cliente (publicar o suscribirse).
# QOS = Calidad de servicio (0, 1 o 2) para las publicaciones.
# RETAIN = Si los mensajes publicados deben ser retenidos por el broker (true o false).