MQTT_HOST=host.containers.internal
MQTT_USER=bunker
MQTT_PASS=bunker
CLIENTS=30
TIMEUNIT=3
TIME=3

# User = Usuario, PASS = Contraseña, HOST = Host del broker MQTT, CLIENTS = Número de clientes a simular,
# TIMEUNIT = Unidad de tiempo (1=horas, 2=minutos, 3=segundos), TIME = Cantidad de unidades de tiempo entre mensajes de un cliente. Por ejemplo, si TIMEUNIT=2 y TIME=5, cada cliente enviará un mensaje cada 5 minutos.