# Environment & Secrets
.env
.env.local
!.env.example
!.env.local.example
# Allow the bootstrap .env for the config service (no real secrets, API key loaded from volume at runtime)
!backend/app/config/.env

# Python
__pycache__/
*.py[cod]
venv/
.venv/

# Logs
*.log

# SSL / Certificates
ssl_certificates/*.pem
ssl_certificates/*.key
ssl_certificates/*.crt
*.pem
*.key

# Application data
backend/logs/
backend/app/*/logs/
*.json.backup
# Ignore runtime dynamic-security files (broker state), but NOT the bootstrap default
dynamic-security.json
!backend/mosquitto/dynsec/dynamic-security.json

# Internal documentation (not for public distribution)
ARCHITECTURE.md
API_DOCUMENTATION.md

# Frontend build artifacts
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.vercel
