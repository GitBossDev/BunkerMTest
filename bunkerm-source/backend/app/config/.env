# Config service environment — API key is overridden at runtime from /nextjs/data/.api_key
API_KEY=default_api_key_replace_in_production
CONFIG_API_PORT=1005
MOSQUITTO_CONF_PATH=/etc/mosquitto/mosquitto.conf
MOSQUITTO_BACKUP_DIR=/tmp/mosquitto_backups
SSL_CERT_PATH=/app/certs/cert.pem
SSL_KEY_PATH=/app/certs/key.pem
ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=INFO
