# ==========================================
# BunkerM Extended - Development Environment
# ==========================================
# Copy this file to .env.dev and update values
# NEVER commit .env.dev to version control

# ------------------------------------------
# PostgreSQL Configuration
# ------------------------------------------
POSTGRES_USER=bunkerm
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_DB=bunkerm_db
POSTGRES_PORT=5432

# Database connection string
DATABASE_URL=postgresql://bunkerm:CHANGE_ME_SECURE_PASSWORD@postgres:5432/bunkerm_db

# ------------------------------------------
# MQTT Broker (Mosquitto) Configuration
# ------------------------------------------
MQTT_BROKER=mosquitto
MQTT_PORT=1900
MQTT_WS_PORT=9001
MQTT_USERNAME=admin
MQTT_PASSWORD=CHANGE_ME_MQTT_PASSWORD
BROKER_CPU_LIMIT_CORES=2
BROKER_MEMORY_LIMIT=4g

# ------------------------------------------
# BunkerM Backend Services
# ------------------------------------------
# API Security
API_KEY=GENERATE_RANDOM_UUID_HERE
JWT_SECRET=GENERATE_RANDOM_SECRET_HERE_MIN_32_CHARS
AUTH_SECRET=GENERATE_ANOTHER_RANDOM_SECRET_HERE

# Service tier (community, pro, enterprise, enterprise_plus)
TIER=enterprise

# Paths
DYNSEC_PATH=/var/lib/mosquitto/dynamic-security.json

# Service Ports
DYNSEC_PORT=1000
MONITOR_PORT=1001
CLIENTLOGS_PORT=1002
AWS_BRIDGE_PORT=1003
AZURE_BRIDGE_PORT=1004
CONFIG_PORT=1005
SMART_ANOMALY_PORT=8100

# ------------------------------------------
# New Extended Services (Funcionalidades Propias)
# ------------------------------------------
DASHBOARD_SERVICE_PORT=1006
BACKUP_SERVICE_PORT=1007
LOAD_SIMULATOR_PORT=1008

# ------------------------------------------
# Frontend Configuration
# ------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:2000
NEXTAUTH_URL=http://localhost:2000
NEXTAUTH_SECRET=GENERATE_NEXTAUTH_SECRET_HERE

# ------------------------------------------
# Nginx Configuration
# ------------------------------------------
NGINX_PORT=2000

# ------------------------------------------
# pgAdmin (Optional - for database management)
# ------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@bunkerm.local
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD
PGADMIN_PORT=5050

# ------------------------------------------
# Backup Configuration
# ------------------------------------------
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE_CRON=0 2 * * *  # 2:00 AM daily

# ------------------------------------------
# Email Notifications (SMTP)
# ------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@bunkerm.local
SMTP_USE_TLS=true

# ------------------------------------------
# SMS Notifications (Twilio)
# ------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ------------------------------------------
# Development Settings
# ------------------------------------------
DEBUG=true
LOG_LEVEL=DEBUG
RELOAD=true

# ------------------------------------------
# Production Settings (override for production)
# ------------------------------------------
# DEBUG=false
# LOG_LEVEL=INFO
# RELOAD=false
# HTTPS=true
